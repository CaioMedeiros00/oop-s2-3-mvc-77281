@model College.Domain.Course

@{
    ViewData["Title"] = "Course Details";
}

<div class="container mt-4">
    <h2>Course Details</h2>
    <hr />

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Course Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Branch</dt>
                <dd class="col-sm-9">@Model.Branch?.Name</dd>

                <dt class="col-sm-3">Start Date</dt>
                <dd class="col-sm-9">@Model.StartDate.ToString("dd/MM/yyyy")</dd>

                <dt class="col-sm-3">End Date</dt>
                <dd class="col-sm-9">@Model.EndDate.ToString("dd/MM/yyyy")</dd>

                <dt class="col-sm-3">Total Enrolments</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-success">@Model.Enrolments.Count</span>
                </dd>

                <dt class="col-sm-3">Faculty Members</dt>
                <dd class="col-sm-9">
                    @if (Model.FacultyMembers.Any())
                    {
                        <ul>
                            @foreach (var faculty in Model.FacultyMembers)
                            {
                                <li>@faculty.Name</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span class="text-muted">No faculty assigned yet</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>
