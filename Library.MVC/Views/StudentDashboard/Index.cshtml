@model College.Domain.StudentProfile

@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="container mt-4">
    <h2>Welcome, @Model.Name!</h2>
    <hr />

    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <h3 class="card-title">@Model.Enrolments.Count</h3>
                    <p class="card-text">Active Enrolments</p>
                    <a asp-action="Enrolments" class="btn btn-primary">View Enrolments</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <h3 class="card-title">@Model.AssignmentResults.Count</h3>
                    <p class="card-text">Assignment Results</p>
                    <a asp-action="Grades" class="btn btn-success">View Grades</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <h3 class="card-title">@Model.ExamResults.Count(er => er.Exam.ResultsReleased)</h3>
                    <p class="card-text">Released Exam Results</p>
                    <a asp-action="Grades" class="btn btn-info">View Results</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header">
            <h4>Your Profile</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Student Number</dt>
                <dd class="col-sm-9">@Model.StudentNumber</dd>

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Phone</dt>
                <dd class="col-sm-9">@Model.Phone</dd>

                <dt class="col-sm-3">Address</dt>
                <dd class="col-sm-9">@Model.Address</dd>

                <dt class="col-sm-3">Date of Birth</dt>
                <dd class="col-sm-9">@Model.DateOfBirth.ToString("dd/MM/yyyy")</dd>
            </dl>
        </div>
    </div>
</div>
