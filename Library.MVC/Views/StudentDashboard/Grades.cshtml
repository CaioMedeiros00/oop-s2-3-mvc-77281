@model College.Domain.StudentProfile

@{
    ViewData["Title"] = "My Grades";
    var assignmentResults = ViewData["AssignmentResults"] as IEnumerable<College.Domain.AssignmentResult>;
    var examResults = ViewData["ExamResults"] as IEnumerable<College.Domain.ExamResult>;
}

<div class="container mt-4">
    <h2>My Grades</h2>
    <hr />

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h4>Assignment Results</h4>
        </div>
        <div class="card-body">
            @if (assignmentResults != null && assignmentResults.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Course</th>
                                <th>Assignment</th>
                                <th>Score</th>
                                <th>Percentage</th>
                                <th>Feedback</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in assignmentResults)
                            {
                                var percentage = (result.Score * 100.0) / result.Assignment.MaxScore;
                                <tr>
                                    <td>@result.Assignment.Course.Name</td>
                                    <td>@result.Assignment.Title</td>
                                    <td>@result.Score / @result.Assignment.MaxScore</td>
                                    <td>
                                        <span class="badge @(percentage >= 70 ? "bg-success" : percentage >= 50 ? "bg-warning" : "bg-danger")">
                                            @percentage.ToString("F1")%
                                        </span>
                                    </td>
                                    <td>@result.Feedback</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No assignment results available yet.</p>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-success text-white">
            <h4>Exam Results (Released Only)</h4>
        </div>
        <div class="card-body">
            @if (examResults != null && examResults.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Course</th>
                                <th>Exam</th>
                                <th>Date</th>
                                <th>Score</th>
                                <th>Percentage</th>
                                <th>Grade</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in examResults)
                            {
                                var percentage = (result.Score * 100.0) / result.Exam.MaxScore;
                                <tr>
                                    <td>@result.Exam.Course.Name</td>
                                    <td>@result.Exam.Title</td>
                                    <td>@result.Exam.Date.ToString("dd/MM/yyyy")</td>
                                    <td>@result.Score / @result.Exam.MaxScore</td>
                                    <td>
                                        <span class="badge @(percentage >= 70 ? "bg-success" : percentage >= 50 ? "bg-warning" : "bg-danger")">
                                            @percentage.ToString("F1")%
                                        </span>
                                    </td>
                                    <td>@result.Grade</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No exam results have been released yet.</p>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
