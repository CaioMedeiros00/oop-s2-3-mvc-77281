@model IEnumerable<Library.Domain.Book>

@{
    ViewData["Title"] = "Books";
}

<h1>Books</h1>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">Create New Book</a>
</div>

<form method="get" asp-action="Index" class="mb-4">
    <div class="row g-3">
        <div class="col-md-3">
            <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" placeholder="Search by title or author..." />
        </div>
        <div class="col-md-2">
            <select name="category" class="form-select">
                <option value="">All Categories</option>
                @foreach (var category in ViewBag.Categories as List<string>)
                {
                    <option value="@category" selected="@(category == ViewBag.Category)">@category</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="availability" class="form-select">
                <option value="">All</option>
                <option value="Available" selected="@(ViewBag.Availability == "Available")">Available</option>
                <option value="OnLoan" selected="@(ViewBag.Availability == "OnLoan")">On Loan</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-secondary">Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>ISBN</th>
            <th>Category</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.Isbn</td>
                <td>@book.Category</td>
                <td>
                    @if (book.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-warning">On Loan</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
