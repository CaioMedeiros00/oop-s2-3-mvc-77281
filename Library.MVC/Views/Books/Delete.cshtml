@model Library.Domain.Book

@{
    ViewData["Title"] = "Delete Book";
}

<h1>Delete Book</h1>

<h3>Are you sure you want to delete this book?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>
        
        <dt class="col-sm-2">Author</dt>
        <dd class="col-sm-10">@Model.Author</dd>
        
        <dt class="col-sm-2">ISBN</dt>
        <dd class="col-sm-10">@Model.Isbn</dd>
        
        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@Model.Category</dd>
        
        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">
            @if (Model.IsAvailable)
            {
                <span class="badge bg-success">Available</span>
            }
            else
            {
                <span class="badge bg-warning">On Loan</span>
            }
        </dd>
    </dl>
    
    @if (Model.Loans.Any())
    {
        <div class="alert alert-warning">
            <strong>Warning:</strong> This book has @Model.Loans.Count loan record(s). Deleting it will remove all associated loan history.
        </div>
    }
    
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
