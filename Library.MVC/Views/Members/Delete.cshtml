@model Library.Domain.Member

@{
    ViewData["Title"] = "Delete Member";
}

<h1>Delete Member</h1>

<h3>Are you sure you want to delete this member?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Full Name</dt>
        <dd class="col-sm-10">@Model.FullName</dd>
        
        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>
        
        <dt class="col-sm-2">Phone</dt>
        <dd class="col-sm-10">@Model.Phone</dd>
    </dl>
    
    @if (Model.Loans.Any())
    {
        <div class="alert alert-warning">
            <strong>Warning:</strong> This member has @Model.Loans.Count loan record(s). Deleting them will remove all associated loan history.
        </div>
    }
    
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
