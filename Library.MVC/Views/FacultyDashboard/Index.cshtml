@model College.Domain.FacultyProfile

@{
    ViewData["Title"] = "Faculty Dashboard";
}

<div class="container mt-4">
    <h2>Welcome, @Model.Name!</h2>
    <hr />

    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <h3 class="card-title">@Model.AssignedCourses.Count</h3>
                    <p class="card-text">Assigned Courses</p>
                    <a asp-action="MyCourses" class="btn btn-primary">View My Courses</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <h3 class="card-title">@Model.AssignedCourses.Sum(c => c.Enrolments.Count)</h3>
                    <p class="card-text">Total Students</p>
                    <a asp-action="Students" class="btn btn-success">View Students</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header bg-primary text-white">
            <h4>Your Profile</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Phone</dt>
                <dd class="col-sm-9">@Model.Phone</dd>
            </dl>
        </div>
    </div>

    @if (Model.AssignedCourses.Any())
    {
        <div class="card mt-4">
            <div class="card-header bg-info text-white">
                <h4>Your Courses</h4>
            </div>
            <div class="card-body">
                <div class="list-group">
                    @foreach (var course in Model.AssignedCourses)
                    {
                        <div class="list-group-item">
                            <div class="d-flex w-100 justify-content-between">
                                <h5 class="mb-1">@course.Name</h5>
                                <small>
                                    <span class="badge bg-success">@course.Enrolments.Count students</span>
                                </small>
                            </div>
                            <p class="mb-1">
                                <strong>Branch:</strong> @course.Branch?.Name<br />
                                <strong>Period:</strong> @course.StartDate.ToString("dd/MM/yyyy") - @course.EndDate.ToString("dd/MM/yyyy")
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
