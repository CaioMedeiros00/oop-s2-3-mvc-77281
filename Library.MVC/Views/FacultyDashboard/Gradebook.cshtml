@model IEnumerable<College.Domain.AssignmentResult>

@{
    ViewData["Title"] = "Gradebook";
    var courses = ViewData["Courses"] as IEnumerable<College.Domain.Course>;
    var selectedCourseId = ViewData["SelectedCourseId"] as int?;
}

<div class="container mt-4">
    <h2>Student Gradebook</h2>
    <hr />

    @if (courses != null && courses.Any())
    {
        <div class="mb-3">
            <label class="form-label">Filter by Course:</label>
            <select class="form-select" onchange="location = this.value;">
                <option value="@Url.Action("Gradebook")">All Courses</option>
                @foreach (var course in courses)
                {
                    <option value="@Url.Action("Gradebook", new { courseId = course.Id })" 
                            @(selectedCourseId == course.Id ? "selected" : "")>
                        @course.Name
                    </option>
                }
            </select>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No assignment results found for the selected course(s).
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Student</th>
                        <th>Student Number</th>
                        <th>Course</th>
                        <th>Assignment</th>
                        <th>Score</th>
                        <th>Percentage</th>
                        <th>Feedback</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var result in Model)
                    {
                        var percentage = (result.Score * 100.0) / result.Assignment.MaxScore;
                        <tr>
                            <td>@result.StudentProfile.Name</td>
                            <td>@result.StudentProfile.StudentNumber</td>
                            <td>@result.Assignment.Course.Name</td>
                            <td>@result.Assignment.Title</td>
                            <td>@result.Score / @result.Assignment.MaxScore</td>
                            <td>
                                <span class="badge @(percentage >= 70 ? "bg-success" : percentage >= 50 ? "bg-warning" : "bg-danger")">
                                    @percentage.ToString("F1")%
                                </span>
                            </td>
                            <td>@result.Feedback</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
