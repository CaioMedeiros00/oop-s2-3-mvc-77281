@model IEnumerable<College.Domain.Course>

@{
    ViewData["Title"] = "My Courses";
}

<div class="container mt-4">
    <h2>My Assigned Courses</h2>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            You have not been assigned to any courses yet.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var course in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <div class="card-header bg-primary text-white">
                            <h5>@course.Name</h5>
                        </div>
                        <div class="card-body">
                            <dl class="row">
                                <dt class="col-sm-4">Branch</dt>
                                <dd class="col-sm-8">@course.Branch?.Name</dd>

                                <dt class="col-sm-4">Start Date</dt>
                                <dd class="col-sm-8">@course.StartDate.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-sm-4">End Date</dt>
                                <dd class="col-sm-8">@course.EndDate.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-sm-4">Enrolled Students</dt>
                                <dd class="col-sm-8">
                                    <span class="badge bg-success">@course.Enrolments.Count</span>
                                </dd>
                            </dl>

                            <div class="mt-3">
                                <a asp-action="Students" asp-route-courseId="@course.Id" class="btn btn-sm btn-primary">View Students</a>
                                <a asp-action="Gradebook" asp-route-courseId="@course.Id" class="btn btn-sm btn-success">Gradebook</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
