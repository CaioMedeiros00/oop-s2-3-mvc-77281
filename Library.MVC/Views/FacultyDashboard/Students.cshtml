@model IEnumerable<College.Domain.CourseEnrolment>

@{
    ViewData["Title"] = "My Students";
    var courses = ViewData["Courses"] as IEnumerable<College.Domain.Course>;
    var selectedCourseId = ViewData["SelectedCourseId"] as int?;
}

<div class="container mt-4">
    <h2>My Students</h2>
    <hr />

    @if (courses != null && courses.Any())
    {
        <div class="mb-3">
            <label class="form-label">Filter by Course:</label>
            <select class="form-select" onchange="location = this.value;">
                <option value="@Url.Action("Students")">All Courses</option>
                @foreach (var course in courses)
                {
                    <option value="@Url.Action("Students", new { courseId = course.Id })" 
                            @(selectedCourseId == course.Id ? "selected" : "")>
                        @course.Name
                    </option>
                }
            </select>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No students found for the selected course(s).
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Student Number</th>
                        <th>Name</th>
                        <th>Course</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th>Enrol Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var enrolment in Model)
                    {
                        <tr>
                            <td>@enrolment.StudentProfile.StudentNumber</td>
                            <td>@enrolment.StudentProfile.Name</td>
                            <td>@enrolment.Course.Name</td>
                            <td>
                                <a href="mailto:@enrolment.StudentProfile.Email">@enrolment.StudentProfile.Email</a>
                            </td>
                            <td>@enrolment.StudentProfile.Phone</td>
                            <td>
                                <span class="badge bg-success">@enrolment.Status</span>
                            </td>
                            <td>@enrolment.EnrolDate.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
