@model IEnumerable<College.Domain.CourseEnrolment>

@{
    ViewData["Title"] = "Enrolments";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Course Enrolments</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New Enrolment
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Student</th>
                    <th>Student Number</th>
                    <th>Course</th>
                    <th>Branch</th>
                    <th>Enrol Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.StudentProfile.Name</td>
                        <td>@item.StudentProfile.StudentNumber</td>
                        <td>@item.Course.Name</td>
                        <td>@item.Course.Branch?.Name</td>
                        <td>@item.EnrolDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            <span class="badge @(item.Status == "Active" ? "bg-success" : "bg-secondary")">
                                @item.Status
                            </span>
                        </td>
                        <td>
                            <a asp-controller="Enrolments" asp-action="RecordAttendance" asp-route-id="@item.Id" class="btn btn-sm btn-info">Attendance</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
