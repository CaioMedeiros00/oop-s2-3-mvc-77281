@model College.Domain.Branch

@{
    ViewData["Title"] = "Delete Branch";
}

<div class="container mt-4">
    <h2>Delete Branch</h2>
    <hr />

    <div class="alert alert-warning">
        <h4>Are you sure you want to delete this branch?</h4>
        <p>This action cannot be undone.</p>
    </div>

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Address</dt>
                <dd class="col-sm-9">@Model.Address</dd>

                <dt class="col-sm-3">Courses</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-info">@Model.Courses.Count</span>
                </dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
