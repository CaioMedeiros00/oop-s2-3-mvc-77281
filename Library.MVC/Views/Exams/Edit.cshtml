@model College.Domain.Exam

@{
    ViewData["Title"] = "Edit Exam";
    var courses = ViewBag.Courses as IEnumerable<College.Domain.Course>;
}

<div class="container mt-4">
    <h2>Edit Exam</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label asp-for="CourseId" class="form-label">Course</label>
                    <select asp-for="CourseId" class="form-select">
                        <option value="">-- Select Course --</option>
                        @if (courses != null)
                        {
                            @foreach (var course in courses)
                            {
                                <option value="@course.Id">@course.Name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CourseId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Date" class="form-label"></label>
                    <input asp-for="Date" type="date" class="form-control" />
                    <span asp-validation-for="Date" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MaxScore" class="form-label"></label>
                    <input asp-for="MaxScore" type="number" class="form-control" />
                    <span asp-validation-for="MaxScore" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="ResultsReleased" type="checkbox" class="form-check-input" />
                    <label asp-for="ResultsReleased" class="form-check-label"></label>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
