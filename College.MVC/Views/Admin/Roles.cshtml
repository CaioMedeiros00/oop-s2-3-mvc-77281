@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>

@{
    ViewData["Title"] = "Role Management";
}

<h1>Role Management</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Create New Role</h5>
            </div>
            <div class="card-body">
                <form asp-action="CreateRole" method="post" class="row g-3">
                    <div class="col-auto">
                        <input type="text" name="roleName" class="form-control" placeholder="Role Name" required />
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary">Create Role</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <h3>Existing Roles</h3>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Role Name</th>
                    <th>Role ID</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var role in Model)
                {
                    <tr>
                        <td>@role.Name</td>
                        <td>@role.Id</td>
                        <td>
                            @if (role.Name != "Admin")
                            {
                                <form asp-action="DeleteRole" asp-route-roleId="@role.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" 
                                            onclick="return confirm('Are you sure you want to delete this role?');">
                                        Delete
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted">Protected</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
