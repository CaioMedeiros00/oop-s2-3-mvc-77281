@model IEnumerable<College.Domain.StudentProfile>

@{
    ViewData["Title"] = "My Students";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>My Students</h1>
        <a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Student Number</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Date of Birth</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var student in Model)
                            {
                                <tr>
                                    <td>@student.StudentNumber</td>
                                    <td>@student.Name</td>
                                    <td>@student.Email</td>
                                    <td>@student.Phone</td>
                                    <td>@(student.DateOfBirth?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                                    <td>
                                        <a asp-action="StudentDetails" asp-route-id="@student.Id" class="btn btn-sm btn-primary">
                                            <i class="bi bi-eye"></i> View Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="mt-3">
                    <p class="text-muted">Total Students: <strong>@Model.Count()</strong></p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>No students enrolled yet.</strong>
            <p class="mb-0">You currently have no students enrolled in your courses.</p>
        </div>
    }
</div>
