@model College.Domain.StudentProfile

@{
    ViewData["Title"] = "Student Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Student Details</h1>
        <a asp-action="Students" class="btn btn-secondary">Back to Students List</a>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-person-circle"></i> Personal Information</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong>Student Number:</strong>
                        <p class="text-muted">@Model.StudentNumber</p>
                    </div>
                    <div class="mb-3">
                        <strong>Name:</strong>
                        <p class="text-muted">@Model.Name</p>
                    </div>
                    <div class="mb-3">
                        <strong>Email:</strong>
                        <p class="text-muted">@Model.Email</p>
                    </div>
                    <div class="mb-3">
                        <strong>Phone:</strong>
                        <p class="text-muted">@(Model.Phone ?? "N/A")</p>
                    </div>
                    <div class="mb-3">
                        <strong>Date of Birth:</strong>
                        <p class="text-muted">@(Model.DateOfBirth?.ToString("MMMM dd, yyyy") ?? "N/A")</p>
                    </div>
                    <div class="mb-3">
                        <strong>Address:</strong>
                        <p class="text-muted">@(Model.Address ?? "N/A")</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <!-- Course Enrolments -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-book"></i> Course Enrolments</h5>
                </div>
                <div class="card-body">
                    @if (Model.Enrolments.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Course</th>
                                        <th>Branch</th>
                                        <th>Enrol Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var enrolment in Model.Enrolments)
                                    {
                                        <tr>
                                            <td>@enrolment.Course?.Name</td>
                                            <td>@enrolment.Course?.Branch?.Name</td>
                                            <td>@enrolment.EnrolDate.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                <span class="badge bg-@(enrolment.Status == "Active" ? "success" : "secondary")">
                                                    @enrolment.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No course enrolments found.</p>
                    }
                </div>
            </div>

            <!-- Assignment Results -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-text"></i> Assignment Results</h5>
                </div>
                <div class="card-body">
                    @if (Model.AssignmentResults.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Assignment</th>
                                        <th>Submitted</th>
                                        <th>Score</th>
                                        <th>Feedback</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var result in Model.AssignmentResults)
                                    {
                                        <tr>
                                            <td>@result.Assignment?.Title</td>
                                            <td>@(result.SubmittedDate?.ToString("MMM dd, yyyy") ?? "Not submitted")</td>
                                            <td>
                                                @if (result.Score > 0)
                                                {
                                                    <span class="badge bg-@(result.Score >= 70 ? "success" : result.Score >= 50 ? "warning" : "danger")">
                                                        @result.Score.ToString("F1")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Not graded</span>
                                                }
                                            </td>
                                            <td>@(result.Feedback ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="mt-3">
                            <p class="text-muted">
                                <strong>Average Score:</strong> 
                                @{
                                    var gradedAssignments = Model.AssignmentResults.Where(r => r.Score > 0).ToList();
                                    if (gradedAssignments.Any())
                                    {
                                        var avgScore = gradedAssignments.Average(r => r.Score);
                                        <span class="badge bg-@(avgScore >= 70 ? "success" : avgScore >= 50 ? "warning" : "danger")">
                                            @avgScore.ToString("F2")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">N/A</span>
                                    }
                                }
                            </p>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No assignment results found.</p>
                    }
                </div>
            </div>

            <!-- Exam Results -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-clipboard-check"></i> Exam Results</h5>
                </div>
                <div class="card-body">
                    @if (Model.ExamResults.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Exam</th>
                                        <th>Score</th>
                                        <th>Grade</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var result in Model.ExamResults)
                                    {
                                        <tr>
                                            <td>@result.Exam?.Title</td>
                                            <td>
                                                <span class="badge bg-@(result.Score >= 70 ? "success" : result.Score >= 50 ? "warning" : "danger")">
                                                    @result.Score.ToString("F1")
                                                </span>
                                            </td>
                                            <td>@(result.Grade ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="mt-3">
                            <p class="text-muted">
                                <strong>Average Exam Score:</strong> 
                                @{
                                    var avgExamScore = Model.ExamResults.Average(r => r.Score);
                                }
                                <span class="badge bg-@(avgExamScore >= 70 ? "success" : avgExamScore >= 50 ? "warning" : "danger")">
                                    @avgExamScore.ToString("F2")
                                </span>
                            </p>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No exam results found.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
