@model IEnumerable<College.Domain.Course>

@{
    ViewData["Title"] = "My Courses";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>My Courses</h1>
        <a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var course in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">@course.Name</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Branch:</strong> @course.Branch?.Name</p>
                            <p><strong>Start Date:</strong> @course.StartDate.ToString("MMM dd, yyyy")</p>
                            <p><strong>End Date:</strong> @course.EndDate.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div class="card-footer">
                            <div class="d-grid gap-2">
                                <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id" class="btn btn-outline-primary btn-sm">View Details</a>
                                <a asp-action="Gradebook" asp-route-courseId="@course.Id" class="btn btn-outline-success btn-sm">View Gradebook</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>No courses assigned yet.</strong>
            <p class="mb-0">You currently have no courses assigned. Please contact the administrator if you believe this is an error.</p>
        </div>
    }
</div>
