@model IEnumerable<College.Domain.CourseEnrolment>

@{
    ViewData["Title"] = "My Courses";
}

<h1>My Course Enrolments</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Course Name</th>
            <th>Branch</th>
            <th>Enrol Date</th>
            <th>Status</th>
            <th>Start Date</th>
            <th>End Date</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Course.Name</td>
                <td>@item.Course.Branch.Name</td>
                <td>@item.EnrolDate.ToShortDateString()</td>
                <td>@item.Status</td>
                <td>@item.Course.StartDate.ToShortDateString()</td>
                <td>@item.Course.EndDate.ToShortDateString()</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
