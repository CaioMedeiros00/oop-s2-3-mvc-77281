@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-body">
                <h2 class="text-center mb-4">@ViewData["Title"]</h2>
                
                <div class="row">
                    <div class="col-md-6">
                        <section>
                            <form id="account" method="post">
                                <hr />
                                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                                <div class="form-floating mb-3">
                                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                                    <label asp-for="Input.Email">Email</label>
                                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                                </div>
                                <div class="form-floating mb-3">
                                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                                    <label asp-for="Input.Password">Password</label>
                                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                                </div>
                                <div class="checkbox mb-3">
                                    <label asp-for="Input.RememberMe" class="form-label">
                                        <input class="form-check-input" asp-for="Input.RememberMe" />
                                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                                    </label>
                                </div>
                                <div>
                                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
                                </div>
                            </form>
                        </section>
                    </div>
                    <div class="col-md-6 border-start">
                        <section>
                            <h5 class="text-center mb-3">Demo Accounts</h5>
                            <div class="alert alert-info">
                                <strong>Administrator</strong><br/>
                                Email: <code>admin@vgc.ie</code><br/>
                                Password: <code>Admin123!</code>
                            </div>
                            <div class="alert alert-success">
                                <strong>Faculty Member</strong><br/>
                                Email: <code>faculty@vgc.ie</code><br/>
                                Password: <code>Faculty123!</code>
                            </div>
                            <div class="alert alert-primary">
                                <strong>Student</strong><br/>
                                Email: <code>student1@vgc.ie</code><br/>
                                Password: <code>Student123!</code>
                            </div>
                            <div class="alert alert-primary">
                                <strong>Student</strong><br/>
                                Email: <code>student2@vgc.ie</code><br/>
                                Password: <code>Student123!</code>
                            </div>
                        </section>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
