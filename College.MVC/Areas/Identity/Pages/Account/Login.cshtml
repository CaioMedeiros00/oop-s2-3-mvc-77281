@page
@using College.MVC.Areas.Identity.Pages.Account
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="row">
    <div class="col-md-8">
        <section>
            <form id="account" method="post">
                <h2>VGC College - Login</h2>
                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="checkbox mb-3">
                    <label asp-for="Input.RememberMe" class="form-label">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
                </div>
                <div class="mt-3">
                    <p>
                        <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                    </p>
                    <p>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register as a new user</a>
                    </p>
                    <p>
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
    <div class="col-md-4">
        <section>
            <h3>Demo Accounts</h3>
            <hr />
            
            <div class="card mb-3">
                <div class="card-header bg-danger text-white">
                    <strong>Administrator</strong>
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>Email:</strong> admin@vgc.ie</p>
                    <p class="mb-0"><strong>Password:</strong> Admin@123</p>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-warning">
                    <strong>Faculty</strong>
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>Email:</strong> john.smith@vgc.ie</p>
                    <p class="mb-1"><strong>Password:</strong> Faculty@123</p>
                    <p class="text-muted small mb-3">Assigned: BSc Computer Science</p>
                    
                    <p class="mb-1"><strong>Email:</strong> sarah.jones@vgc.ie</p>
                    <p class="mb-1"><strong>Password:</strong> Faculty@123</p>
                    <p class="text-muted small mb-0">Assigned: BA Business Management</p>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-success text-white">
                    <strong>Student</strong>
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>Email:</strong> alice.murphy@student.vgc.ie</p>
